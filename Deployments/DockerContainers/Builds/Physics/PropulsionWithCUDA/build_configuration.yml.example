# https://docs.nvidia.com/deeplearning/frameworks/support-matrix/index.html
# We need a PyTorch container because a NVIDIA CUDA container doesn't have
# nvidia-smi.
#
# To check available tags:
# https://catalog.ngc.nvidia.com/orgs/nvidia/containers/pytorch/tags
docker_image_name: propulsion-with-cuda:26.02-py3
base_image: nvcr.io/nvidia/pytorch:26.02-py3

dockerfile_components:
  - label: "Dockerfile.header"
    path: "../../../CommonComponents/Dockerfile.header"
  - label: "Dockerfile.minimal_base"
    path: "../../../CommonComponents/Dockerfile.minimal_base"
  - label: "Dockerfile.cpp_development"
    path: "../../../CommonComponents/Dockerfile.cpp_development"

# At this point here are the abbreviated results for
# pip list
# flash_attn                       2.7.4.post1+nv26.2.44259020
# Jinja2                           3.1.6
# numpy                            2.1.0
# tensorrt                         10.15.1.29
# tokenizers                       0.22.2
# torch                            2.11.0a0+eb65b36914.nv26.2
# torchvision                      0.25.0a0+1e53952f.nv26.2.44259020

  - label: "Dockerfile.rust"
    path: "../../../CommonComponents/Dockerfile.rust"
  - label: "Dockerfile.python"
    path: "../../../CommonComponents/Dockerfile.python"
  - label: "Dockerfile.python_development"
    path: "../../../CommonComponents/Dockerfile.python_development"
  - label: "Dockerfile.coolprop"
    path: "Dockerfile.coolprop"